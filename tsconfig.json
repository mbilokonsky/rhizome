{
  "compilerOptions": {
    "target": "ES6",
    "module": "CommonJS",
    "esModuleInterop": true,
    "moduleResolution": "Node",
    "sourceMap": true,
    "baseUrl": ".",
    "outDir": "dist",
    "importsNotUsedAsValues": "remove",
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src/**/*",
    "util/**/*",
    "examples/**/*",
    "scratch/**/*",
    "__tests__/**/*"
  ],
  "exclude": ["node_modules"]
}
