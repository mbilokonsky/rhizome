{
  "compilerOptions": {
    "target": "ES6",
    "module": "CommonJS",
    "esModuleInterop": true,
    "moduleResolution": "Node",
    "sourceMap": true,
    "baseUrl": ".",
    "rootDir": ".",
    "outDir": "dist",
    "importsNotUsedAsValues": "remove",
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "jest"],
    "typeRoots": [
      "./node_modules/@types"
    ],
    "paths": {
      "@src": ["./src"],
      "@src/*": ["./src/*"],
      "@test-helpers": ["__tests__/__helpers__"],
      "@test-helpers/*": ["__tests__/__helpers__/*"]
    },
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": false
  },
  "include": [
    "src/**/*",
    "util/**/*",
    "examples/**/*",
    "scratch/**/*",
    "__tests__/**/*"
  ],
  "exclude": ["node_modules"]
}
